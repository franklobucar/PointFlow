<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PointFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="pf-shell">

        <!-- ── Sidebar ── -->
        <aside class="pf-sidebar">
            <a class="pf-brand" asp-controller="Home" asp-action="Index">
                <span class="pf-brand-icon">⚡</span>
                PointFlow
            </a>

            <nav class="pf-nav">
                <span class="pf-nav-label">Main</span>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "is-active" : "")"
                   asp-controller="Home" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    Početna
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "is-active" : "")"
                   asp-controller="User" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                    Korisnici
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Task" ? "is-active" : "")"
                   asp-controller="Task" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    Taskovi
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reward" ? "is-active" : "")"
                   asp-controller="Reward" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    Nagrade
                </a>

                <span class="pf-nav-label" style="margin-top:1rem;">Organizacija</span>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Category" ? "is-active" : "")"
                   asp-controller="Category" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                    Kategorije
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tag" ? "is-active" : "")"
                   asp-controller="Tag" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><circle cx="7" cy="7" r="1" fill="currentColor"/></svg>
                    Tagovi
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PomodoroSession" ? "is-active" : "")"
                   asp-controller="PomodoroSession" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                    Pomodoro
                </a>
                <a class="pf-nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Quiz" ? "is-active" : "")"
                   asp-controller="Quiz" asp-action="Index">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3h6"/><path d="M10 8h4"/><path d="M4 6h16"/><rect x="4" y="6" width="16" height="14" rx="2"/><path d="M8 12h8"/><path d="M8 16h5"/></svg>
                    Kvizovi
                </a>
            </nav>

            <div class="pf-sidebar-footer">
                <span class="pf-version">v1.0.0</span>
            </div>
        </aside>

        <!-- ── Content area ── -->
        <div class="pf-content-wrap">

            <!-- Topbar with breadcrumbs -->
            <header class="pf-topbar">
                <nav class="pf-breadcrumbs" aria-label="breadcrumb">
                    <a class="pf-crumb" asp-controller="Home" asp-action="Index">Početna</a>
                    @if (ViewData["Breadcrumb"] is IEnumerable<(string Label, string? Url)> crumbs)
                    {
                        foreach (var crumb in crumbs)
                        {
                            <span class="pf-crumb-sep">›</span>
                            if (crumb.Url is not null)
                            {
                                <a class="pf-crumb" href="@crumb.Url">@crumb.Label</a>
                            }
                            else
                            {
                                <span class="pf-crumb pf-crumb--current">@crumb.Label</span>
                            }
                        }
                    }
                </nav>
            </header>

            <main class="pf-main">
                @RenderBody()
            </main>

        </div>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
