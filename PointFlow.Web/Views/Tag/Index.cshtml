@model IEnumerable<PointFlow.Model.Tag>

@{
    ViewData["Title"] = "Tagovi";
}

<div class="page-header">
    <h1 class="page-title">Tagovi</h1>
    <p class="page-subtitle">Sve oznake za organizaciju taskova</p>
</div>

<div class="tag-page-grid">
    @foreach (var tag in Model)
    {
        <div class="tag-page-card">
            <span class="tag-pill">#@tag.Name</span>
            <a asp-controller="Tag" asp-action="Details" asp-route-id="@tag.Id" class="fwd-link">
                Pregled taskova
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>
    }
</div>
