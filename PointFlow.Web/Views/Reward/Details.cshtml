@using PointFlow.Model
@model Reward

@{
    ViewData["Title"] = Model.Name;
}

<a class="back-link" asp-controller="Reward" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
    Natrag na Nagrade
</a>

<div class="detail-card">
    <div class="detail-header">
        <h1 class="detail-title">@Model.Name</h1>
        <span class="lock-badge @(Model.IsLocked ? "locked" : "unlocked")">
            @(Model.IsLocked ? "🔒 Locked" : "🔓 Unlocked")
        </span>
    </div>

    <p class="detail-desc">@Model.Description</p>

    <div class="detail-grid">
        <div class="detail-item">
            <div class="detail-item-label">Cijena</div>
            <div class="detail-item-value value-points">@Model.PointsCost pts</div>
        </div>
        <div class="detail-item">
            <div class="detail-item-label">Status</div>
            <div class="detail-item-value" style="color: @(Model.IsLocked ? "var(--red)" : "var(--green)")">
                @(Model.IsLocked ? "Zaključano" : "Otključano")
            </div>
        </div>
        <div class="detail-item">
            <div class="detail-item-label">Korisnik</div>
            <div class="detail-item-value">
                <a asp-controller="User" asp-action="Details" asp-route-id="@Model.AppUserId"
                   style="color: var(--purple); text-decoration: none;">
                    User #@Model.AppUserId
                </a>
            </div>
        </div>
        @if (!Model.IsLocked)
        {
            <div class="detail-item">
                <div class="detail-item-label">Otključano</div>
                <div class="detail-item-value value-date">@Model.UnlockedAt.ToString("MMM dd, yyyy")</div>
            </div>
        }
    </div>
</div>
