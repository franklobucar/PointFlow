@using PointFlow.Model
@model PointTask

@{
    ViewData["Title"] = Model.Title;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PointFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #0f0f13;
            color: #ffffff;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 240px 1fr;
        }

        .sidebar {
            background: rgba(255,255,255,0.03);
            border-right: 1px solid rgba(255,255,255,0.08);
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #b026ff;
            margin-bottom: 2rem;
            letter-spacing: -0.5px;
        }

        .sidebar a {
            display: block;
            padding: 0.6rem 1rem;
            border-radius: 10px;
            color: #a0a0b0;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(176, 38, 255, 0.1);
            color: #ffffff;
        }

        .main {
            padding: 2.5rem 3rem;
            overflow-y: auto;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #a0a0b0;
            text-decoration: none;
            font-size: 0.85rem;
            margin-bottom: 1.8rem;
            transition: color 0.2s;
        }

        .back-link:hover { color: #ffffff; }

        .detail-card {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 2rem 2.4rem;
            max-width: 680px;
        }

        .detail-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .detail-title {
            font-size: 1.6rem;
            font-weight: 700;
            line-height: 1.3;
        }

        .status-pill {
            flex-shrink: 0;
            border-radius: 20px;
            padding: 0.3rem 1rem;
            font-size: 0.78rem;
            font-weight: 600;
        }

        .status-pill.completed {
            background: rgba(0,230,118,0.12);
            color: #00e676;
            border: 1px solid rgba(0,230,118,0.3);
        }

        .status-pill.pending {
            background: rgba(255,255,255,0.06);
            color: #a0a0b0;
            border: 1px solid rgba(255,255,255,0.12);
        }

        .detail-desc {
            color: #a0a0b0;
            font-size: 0.9rem;
            line-height: 1.65;
            margin-bottom: 1.8rem;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .detail-item {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 0.85rem 1.1rem;
        }

        .detail-item-label {
            font-size: 0.72rem;
            font-weight: 600;
            color: #a0a0b0;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            margin-bottom: 0.3rem;
        }

        .detail-item-value {
            font-size: 0.95rem;
            font-weight: 600;
        }

        .value-priority-high   { color: #ff3366; }
        .value-priority-medium { color: #ffa500; }
        .value-priority-low    { color: #00e676; }
        .value-points          { color: #b026ff; }
        .value-date            { color: #a0a0b0; font-weight: 400; }
    </style>
</head>
<body>

<nav class="sidebar">
    <div class="sidebar-brand">⚡ PointFlow</div>
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <a asp-controller="User" asp-action="Index">Users</a>
    <a asp-controller="Task" asp-action="Index" class="active">Tasks</a>
</nav>

<main class="main">
    <a class="back-link" asp-controller="Task" asp-action="Index">← Back to Tasks</a>

    <div class="detail-card">
        <div class="detail-header">
            <h1 class="detail-title">@Model.Title</h1>
            <span class="status-pill @(Model.IsCompleted ? "completed" : "pending")">
                @(Model.IsCompleted ? "Completed" : "Pending")
            </span>
        </div>

        <p class="detail-desc">@Model.Description</p>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Priority</div>
                <div class="detail-item-value value-priority-@Model.Priority.ToString().ToLower()">
                    @Model.Priority
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Points Reward</div>
                <div class="detail-item-value value-points">+@Model.PointsReward pts</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Category ID</div>
                <div class="detail-item-value">@Model.CategoryId</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">User ID</div>
                <div class="detail-item-value">
                    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.AppUserId"
                       style="color:#b026ff; text-decoration:none;">
                        User #@Model.AppUserId
                    </a>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Created</div>
                <div class="detail-item-value value-date">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>
</main>

</body>
</html>
