@using PointFlow.Model
@model PointTask

@{
    ViewData["Title"] = Model.Title;
}

<a class="back-link" asp-controller="Task" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
    Natrag na Taskove
</a>

    <div class="detail-card">
        <div class="detail-header">
            <h1 class="detail-title">@Model.Title</h1>
            <span class="status-pill @(Model.IsCompleted ? "completed" : "pending")">
                @(Model.IsCompleted ? "Completed" : "Pending")
            </span>
        </div>

        <p class="detail-desc">@Model.Description</p>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Priority</div>
                <div class="detail-item-value value-priority-@Model.Priority.ToString().ToLower()">
                    @Model.Priority
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Points Reward</div>
                <div class="detail-item-value value-points">+@Model.PointsReward pts</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Category</div>
                <div class="detail-item-value">
                    <a asp-controller="Category" asp-action="Details" asp-route-id="@Model.CategoryId"
                       class="detail-link">
                        @Model.Category.Name
                    </a>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">User</div>
                <div class="detail-item-value">
                    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.AppUserId"
                       class="detail-link">
                        @Model.AppUser.Username
                    </a>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Created</div>
                <div class="detail-item-value value-date">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>
