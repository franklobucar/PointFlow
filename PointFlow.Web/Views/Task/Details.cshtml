@using PointFlow.Model
@model PointTask

@{
    ViewData["Title"] = Model.Title;
}

<a class="back-link" asp-controller="Task" asp-action="Index">← Natrag na Taskove</a>

    <div class="detail-card">
        <div class="detail-header">
            <h1 class="detail-title">@Model.Title</h1>
            <span class="status-pill @(Model.IsCompleted ? "completed" : "pending")">
                @(Model.IsCompleted ? "Completed" : "Pending")
            </span>
        </div>

        <p class="detail-desc">@Model.Description</p>

        <div class="detail-grid">
            <div class="detail-item">
                <div class="detail-item-label">Priority</div>
                <div class="detail-item-value value-priority-@Model.Priority.ToString().ToLower()">
                    @Model.Priority
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Points Reward</div>
                <div class="detail-item-value value-points">+@Model.PointsReward pts</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Category ID</div>
                <div class="detail-item-value">@Model.CategoryId</div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">User ID</div>
                <div class="detail-item-value">
                    <a asp-controller="User" asp-action="Details" asp-route-id="@Model.AppUserId"
                       style="color:#b026ff; text-decoration:none;">
                        User #@Model.AppUserId
                    </a>
                </div>
            </div>
            <div class="detail-item">
                <div class="detail-item-label">Created</div>
                <div class="detail-item-value value-date">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>
