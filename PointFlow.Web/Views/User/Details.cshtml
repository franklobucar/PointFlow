@using PointFlow.Model
@model AppUser

@{
    ViewData["Title"] = Model.Username;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PointFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #0f0f13;
            color: #ffffff;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 240px 1fr;
        }

        .sidebar {
            background: rgba(255,255,255,0.03);
            border-right: 1px solid rgba(255,255,255,0.08);
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #b026ff;
            margin-bottom: 2rem;
            letter-spacing: -0.5px;
        }

        .sidebar a {
            display: block;
            padding: 0.6rem 1rem;
            border-radius: 10px;
            color: #a0a0b0;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(176, 38, 255, 0.1);
            color: #ffffff;
        }

        .main {
            padding: 2.5rem 3rem;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }

        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            color: #a0a0b0;
            text-decoration: none;
            font-size: 0.85rem;
            transition: color 0.2s;
        }

        .back-link:hover { color: #ffffff; }

        /* ── Profile card ── */
        .profile-card {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 2rem 2.4rem;
            display: flex;
            align-items: center;
            gap: 1.8rem;
        }

        .profile-avatar {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            background: linear-gradient(135deg, #b026ff 0%, #7b00cc 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .profile-info { flex: 1; }

        .profile-username {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.25rem;
        }

        .profile-email { color: #a0a0b0; font-size: 0.88rem; }

        .profile-joined {
            font-size: 0.78rem;
            color: #a0a0b0;
            margin-top: 0.4rem;
        }

        .stats-row {
            display: flex;
            gap: 1rem;
            margin-top: 1rem;
        }

        .stat-pill {
            border-radius: 10px;
            padding: 0.5rem 1.1rem;
            font-size: 0.82rem;
            font-weight: 600;
        }

        .stat-pill.balance {
            background: rgba(0,230,118,0.1);
            color: #00e676;
            border: 1px solid rgba(0,230,118,0.25);
        }

        .stat-pill.total {
            background: rgba(176,38,255,0.1);
            color: #b026ff;
            border: 1px solid rgba(176,38,255,0.25);
        }

        /* ── Section heading ── */
        .section-title {
            font-size: 1rem;
            font-weight: 600;
            color: #a0a0b0;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 0.2rem;
        }

        /* ── Empty state ── */
        .empty-state {
            color: #a0a0b0;
            font-size: 0.85rem;
            padding: 1rem 0;
        }

        /* ── Reward list ── */
        .reward-list {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        .reward-item {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 12px;
            padding: 1rem 1.4rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            transition: transform 0.2s, border-color 0.2s;
        }

        .reward-item:hover {
            transform: translateY(-3px);
            border-color: rgba(255,255,255,0.16);
        }

        .reward-name { font-size: 0.95rem; font-weight: 600; }
        .reward-desc { font-size: 0.78rem; color: #a0a0b0; margin-top: 0.2rem; }

        .reward-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 0.35rem;
            flex-shrink: 0;
        }

        .reward-cost {
            font-size: 0.85rem;
            font-weight: 700;
            color: #b026ff;
        }

        .lock-badge {
            border-radius: 8px;
            padding: 0.18rem 0.6rem;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .lock-badge.unlocked {
            background: rgba(0,230,118,0.1);
            color: #00e676;
            border: 1px solid rgba(0,230,118,0.25);
        }

        .lock-badge.locked {
            background: rgba(255,51,102,0.1);
            color: #ff3366;
            border: 1px solid rgba(255,51,102,0.25);
        }
    </style>
</head>
<body>

<nav class="sidebar">
    <div class="sidebar-brand">⚡ PointFlow</div>
    <a asp-controller="Home" asp-action="Index">Dashboard</a>
    <a asp-controller="User" asp-action="Index" class="active">Users</a>
    <a asp-controller="Task" asp-action="Index">Tasks</a>
</nav>

<main class="main">
    <a class="back-link" asp-controller="User" asp-action="Index">← Back to Users</a>

    <div class="profile-card">
        <div class="profile-avatar">@Model.Username[0].ToString().ToUpper()</div>
        <div class="profile-info">
            <div class="profile-username">@Model.Username</div>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-joined">Member since @Model.CreatedAt.ToString("MMMM yyyy")</div>
            <div class="stats-row">
                <span class="stat-pill balance">Balance: @Model.CurrentBalance pts</span>
                <span class="stat-pill total">Total earned: @Model.TotalPointsEarned pts</span>
            </div>
        </div>
    </div>

    <div>
        <div class="section-title">Rewards</div>
        @if (Model.Rewards is null || !Model.Rewards.Any())
        {
            <p class="empty-state">No rewards yet.</p>
        }
        else
        {
            <div class="reward-list">
                @foreach (var reward in Model.Rewards)
                {
                    <div class="reward-item">
                        <div>
                            <div class="reward-name">@reward.Name</div>
                            <div class="reward-desc">@reward.Description</div>
                        </div>
                        <div class="reward-right">
                            <span class="reward-cost">@reward.PointsCost pts</span>
                            <span class="lock-badge @(reward.IsLocked ? "locked" : "unlocked")">
                                @(reward.IsLocked ? "Locked" : "Unlocked")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</main>

</body>
</html>
