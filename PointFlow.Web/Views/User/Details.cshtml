@using PointFlow.Model
@model AppUser

@{
    ViewData["Title"] = Model.Username;
}

<a class="back-link" asp-controller="User" asp-action="Index">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
    Natrag na Korisnike
</a>

    <div class="profile-card">
        <div class="profile-avatar">@Model.Username[0].ToString().ToUpper()</div>
        <div class="profile-info">
            <div class="profile-username">@Model.Username</div>
            <div class="profile-email">@Model.Email</div>
            <div class="profile-joined">Member since @Model.CreatedAt.ToString("MMMM yyyy")</div>
            <div class="stats-row">
                <span class="stat-pill balance">Balance: @Model.CurrentBalance pts</span>
                <span class="stat-pill total">Total earned: @Model.TotalPointsEarned pts</span>
            </div>
        </div>
    </div>

    <div>
        <div class="section-title">Taskovi</div>
        @if (Model.Tasks is null || !Model.Tasks.Any())
        {
            <p class="empty-state">Nema taskova.</p>
        }
        else
        {
            <div class="task-list">
                @foreach (var task in Model.Tasks)
                {
                    <div class="task-list-item">
                        <div class="task-list-item__left">
                            <span class="priority-tag priority-@task.Priority.ToString().ToLower()">@task.Priority</span>
                            @if (task.IsCompleted)
                            {
                                <span class="status-pill status-pill--done">Završeno</span>
                            }
                            else
                            {
                                <span class="status-pill status-pill--pending">Na čekanju</span>
                            }
                        </div>
                        <a asp-controller="Task" asp-action="Details" asp-route-id="@task.Id"
                           class="task-list-item__title">@task.Title</a>
                        <span class="points-tag">+@task.PointsReward XP</span>
                    </div>
                }
            </div>
        }
    </div>

    <div>
        <div class="section-title">Rewards</div>
        @if (Model.Rewards is null || !Model.Rewards.Any())
        {
            <p class="empty-state">No rewards yet.</p>
        }
        else
        {
            <div class="reward-list">
                @foreach (var reward in Model.Rewards)
                {
                    <div class="reward-item">
                        <div>
                            <div class="reward-name">@reward.Name</div>
                            <div class="reward-desc">@reward.Description</div>
                        </div>
                        <div class="reward-right">
                            <span class="reward-cost">@reward.PointsCost pts</span>
                            <span class="lock-badge @(reward.IsLocked ? "locked" : "unlocked")">
                                @(reward.IsLocked ? "Locked" : "Unlocked")
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
