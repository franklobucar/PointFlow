@using PointFlow.Model
@model List<AppUser>

@{
    ViewData["Title"] = "Users";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PointFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', 'Segoe UI', sans-serif;
            background: #0f0f13;
            color: #ffffff;
            min-height: 100vh;
            display: grid;
            grid-template-columns: 240px 1fr;
        }

        .sidebar {
            background: rgba(255,255,255,0.03);
            border-right: 1px solid rgba(255,255,255,0.08);
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 700;
            color: #b026ff;
            margin-bottom: 2rem;
            letter-spacing: -0.5px;
        }

        .sidebar a {
            display: block;
            padding: 0.6rem 1rem;
            border-radius: 10px;
            color: #a0a0b0;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            transition: background 0.2s, color 0.2s;
        }

        .sidebar a:hover, .sidebar a.active {
            background: rgba(176, 38, 255, 0.1);
            color: #ffffff;
        }

        .main {
            padding: 2.5rem 3rem;
            overflow-y: auto;
        }

        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 2rem;
        }

        .page-header h1 { font-size: 1.8rem; font-weight: 700; }

        .badge-count {
            background: rgba(176,38,255,0.15);
            color: #b026ff;
            border: 1px solid rgba(176,38,255,0.3);
            border-radius: 20px;
            padding: 0.25rem 0.85rem;
            font-size: 0.8rem;
            font-weight: 600;
        }

        /* ── User grid ── */
        .user-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 1.25rem;
        }

        .user-card {
            backdrop-filter: blur(12px);
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 16px;
            padding: 1.6rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            text-decoration: none;
            color: inherit;
            transition: transform 0.2s, border-color 0.2s;
        }

        .user-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255,255,255,0.18);
        }

        .user-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, #b026ff 0%, #7b00cc 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
        }

        .user-info { display: flex; align-items: center; gap: 1rem; }

        .user-name {
            font-size: 1rem;
            font-weight: 600;
        }

        .user-email {
            font-size: 0.78rem;
            color: #a0a0b0;
            margin-top: 0.15rem;
        }

        .user-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.6rem;
        }

        .stat {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 10px;
            padding: 0.6rem 0.85rem;
        }

        .stat-label {
            font-size: 0.68rem;
            font-weight: 600;
            color: #a0a0b0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .stat-value {
            font-size: 1rem;
            font-weight: 700;
            margin-top: 0.15rem;
        }

        .stat-value.balance { color: #00e676; }
        .stat-value.total   { color: #b026ff; }
    </style>
</head>
<body>

<nav class="sidebar">
    <div class="sidebar-brand">⚡ PointFlow</div>
    <a asp-controller="Home"  asp-action="Index">Dashboard</a>
    <a asp-controller="User"  asp-action="Index" class="active">Users</a>
    <a asp-controller="Task"  asp-action="Index">Tasks</a>
</nav>

<main class="main">
    <div class="page-header">
        <h1>Users</h1>
        <span class="badge-count">@Model.Count total</span>
    </div>

    <div class="user-grid">
        @foreach (var user in Model)
        {
            <a class="user-card" asp-controller="User" asp-action="Details" asp-route-id="@user.Id">
                <div class="user-info">
                    <div class="user-avatar">@user.Username[0].ToString().ToUpper()</div>
                    <div>
                        <div class="user-name">@user.Username</div>
                        <div class="user-email">@user.Email</div>
                    </div>
                </div>
                <div class="user-stats">
                    <div class="stat">
                        <div class="stat-label">Balance</div>
                        <div class="stat-value balance">@user.CurrentBalance pts</div>
                    </div>
                    <div class="stat">
                        <div class="stat-label">Total Earned</div>
                        <div class="stat-value total">@user.TotalPointsEarned pts</div>
                    </div>
                </div>
            </a>
        }
    </div>
</main>

</body>
</html>
