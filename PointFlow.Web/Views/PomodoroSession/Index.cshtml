@model IEnumerable<PointFlow.Model.PomodoroSession>

@{
    ViewData["Title"] = "Pomodoro Sesije";
}

<div class="page-header">
    <h1 class="page-title">Pomodoro Sesije</h1>
    <p class="page-subtitle">Evidencija svih radnih sesija</p>
</div>

<div class="session-list">
    @foreach (var session in Model)
    {
        <div class="session-card">
            <div class="session-card__left">
                <span class="session-icon">🍅</span>
                <div class="session-info">
                    <span class="session-duration">@session.DurationMinutes min</span>
                    <span class="session-date">@session.StartTime.ToString("dd.MM.yyyy HH:mm")</span>
                </div>
            </div>
            <div class="session-card__mid">
                <span class="session-task-id">Task #@session.PointTaskId</span>
                @if (session.IsQuizPassed)
                {
                    <span class="badge badge--green">Quiz ✓</span>
                }
                else
                {
                    <span class="badge badge--red">Quiz ✗</span>
                }
            </div>
            <div class="session-card__right">
                <a asp-controller="PomodoroSession" asp-action="Details" asp-route-id="@session.Id" class="fwd-link">
                    Detalji
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
            </div>
        </div>
    }
</div>
