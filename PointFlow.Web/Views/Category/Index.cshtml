@model IEnumerable<PointFlow.Model.Category>

@{
    ViewData["Title"] = "Kategorije";
}

<div class="page-header">
    <h1 class="page-title">Kategorije</h1>
    <p class="page-subtitle">Sve kategorije taskova</p>
</div>

<div class="category-grid">
    @foreach (var category in Model)
    {
        <div class="category-card">
            <div class="category-icon">🗂️</div>
            <div class="category-body">
                <h3 class="category-name">@category.Name</h3>
                <p class="category-desc">@category.Description</p>
            </div>
            <a asp-controller="Category" asp-action="Details" asp-route-id="@category.Id" class="fwd-link">
                Detalji
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
        </div>
    }
</div>
