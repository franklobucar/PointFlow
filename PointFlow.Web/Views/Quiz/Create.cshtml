@model PointFlow.Model.Quiz

@{
    ViewData["Title"] = "Novi kviz";
}

<a asp-controller="Quiz" asp-action="Index" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
    Nazad na kvizove
</a>

<div class="form-card">
    <div class="page-header">
        <div>
            <h1 class="page-title">Novi kviz</h1>
            <p class="page-subtitle">Unesite pitanje i povežite ga s pomodoro sesijom</p>
        </div>
    </div>

    <form asp-action="Create" method="post" class="pf-form">
        @await Html.PartialAsync("_QuizForm", Model)

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">Spremi</button>
            <a asp-controller="Quiz" asp-action="Index" class="btn-ghost">Odustani</a>
        </div>
    </form>
</div>
