@model PointFlow.Model.Quiz

@{
    ViewData["Title"] = $"Uredi kviz #{Model.Id}";
}

<a asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Id" class="back-link">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><polyline points="12 19 5 12 12 5"/></svg>
    Nazad na detalje kviza
</a>

<div class="form-card">
    <div class="page-header">
        <div>
            <h1 class="page-title">Uredi kviz #@Model.Id</h1>
            <p class="page-subtitle">Ažurirajte pitanje ili odgovore</p>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="pf-form">
        <input type="hidden" asp-for="Id" />
        @await Html.PartialAsync("_QuizForm", Model)

        <div class="form-actions">
            <button type="submit" class="btn-primary-custom">Spremi promjene</button>
            <a asp-controller="Quiz" asp-action="Details" asp-route-id="@Model.Id" class="btn-ghost">Odustani</a>
        </div>
    </form>
</div>
